# Lantern - Narrative Intelligence Platform
# Environment Configuration Example
# Copy this file to .env and fill in your values

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=Lantern
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# =============================================================================
# Database Settings
# =============================================================================
DATABASE_URL=postgresql+asyncpg://lantern:lantern@localhost:5432/lantern
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# =============================================================================
# Redis Settings
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# =============================================================================
# AWS / S3 Settings
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=lantern-artifacts
# S3_ENDPOINT_URL=http://localhost:9000  # For MinIO/LocalStack

# =============================================================================
# AI Provider Settings
# =============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# =============================================================================
# Temporal Workflow Settings
# =============================================================================
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=lantern
TEMPORAL_TASK_QUEUE=lantern-tasks

# =============================================================================
# Celery Settings (defaults to REDIS_URL if not set)
# =============================================================================
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# Observability Settings
# =============================================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Authentication Settings
# =============================================================================
JWT_SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-SECURE-SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Content Processing Settings
# =============================================================================
MAX_CONTENT_LENGTH=100000
WHISPER_MODEL=base

# =============================================================================
# Rate Limiting Settings
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
