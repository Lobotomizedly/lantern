# =============================================================================
# Lantern - API Keys (Fill in your keys here)
# =============================================================================
# After adding your keys, copy this content to .env or run:
#   cat .env.keys >> .env
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: AI/ML API Keys
# -----------------------------------------------------------------------------

# OpenAI API key (for embeddings with text-embedding-3-small)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API key (for Claude - extraction, agents, generation)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL: Additional Services
# -----------------------------------------------------------------------------

# Hugging Face token (for downloading models like sentence-transformers)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# NewsAPI key (for news collection)
# Get from: https://newsapi.org/register
NEWSAPI_KEY=

# Twitter/X API credentials (for social collection)
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Cohere API key (optional, for reranking)
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# -----------------------------------------------------------------------------
# SECURITY: Generate these for production
# -----------------------------------------------------------------------------

# JWT secret key - generate with: openssl rand -hex 32
SECRET_KEY=

# NextAuth secret - generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
