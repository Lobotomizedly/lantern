# =============================================================================
# Lantern - Narrative Intelligence Platform
# Environment Variables Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# NEVER commit .env files to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode (set to false in production)
DEBUG=true

# Secret key for JWT tokens and session encryption
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production-minimum-32-chars

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------

# PostgreSQL connection settings
POSTGRES_USER=lantern
POSTGRES_PASSWORD=lantern_secret
POSTGRES_DB=lantern
POSTGRES_PORT=5432

# Full database URL (constructed from above, or override directly)
# DATABASE_URL=postgresql+asyncpg://lantern:lantern_secret@localhost:5432/lantern

# -----------------------------------------------------------------------------
# Redis Cache & Message Broker
# -----------------------------------------------------------------------------

# Redis connection
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379/0

# Celery broker and result backend (uses different Redis databases)
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# OpenSearch
# -----------------------------------------------------------------------------

# OpenSearch connection settings
OPENSEARCH_PORT=9200
OPENSEARCH_PERF_PORT=9600
OPENSEARCH_DASHBOARDS_PORT=5601
# OPENSEARCH_URL=http://localhost:9200

# -----------------------------------------------------------------------------
# MinIO (S3-Compatible Storage)
# -----------------------------------------------------------------------------

# MinIO root credentials (admin access)
MINIO_ROOT_USER=lantern_admin
MINIO_ROOT_PASSWORD=lantern_secret_key

# MinIO ports
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO connection settings for application
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=lantern_admin
# MINIO_SECRET_KEY=lantern_secret_key
# MINIO_SECURE=false

# S3 bucket names
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_MEDIA=media
MINIO_BUCKET_EXPORTS=exports
MINIO_BUCKET_MODELS=models

# -----------------------------------------------------------------------------
# Temporal (Workflow Orchestration)
# -----------------------------------------------------------------------------

# Temporal server settings
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080
# TEMPORAL_HOST=localhost

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------

# Backend server port
BACKEND_PORT=8000

# Number of uvicorn workers
BACKEND_WORKERS=4

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------

# Frontend server port
FRONTEND_PORT=3000

# Node environment
NODE_ENV=development

# Public API URL (accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# -----------------------------------------------------------------------------
# AI/ML API Keys
# -----------------------------------------------------------------------------

# OpenAI API key (for GPT models and embeddings)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Hugging Face token (for model downloads)
HUGGINGFACE_TOKEN=hf_your-huggingface-token

# Cohere API key (optional, for reranking)
# COHERE_API_KEY=your-cohere-api-key

# -----------------------------------------------------------------------------
# Worker Settings
# -----------------------------------------------------------------------------

# Celery worker concurrency (number of parallel tasks)
CELERY_WORKER_CONCURRENCY=4

# Prefetch multiplier (tasks to prefetch per worker)
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# Model cache directory
MODEL_CACHE_DIR=/app/models

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------

# Flower (Celery monitoring) settings
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# Sentry DSN (error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable structured JSON logging
LOG_JSON_FORMAT=false

# -----------------------------------------------------------------------------
# Email Settings (for notifications)
# -----------------------------------------------------------------------------

# SMTP server settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@lantern.ai
# SMTP_TLS=true

# -----------------------------------------------------------------------------
# OAuth Settings (optional)
# -----------------------------------------------------------------------------

# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# API rate limit (requests per minute per user)
RATE_LIMIT_PER_MINUTE=60

# Burst rate limit (maximum burst requests)
RATE_LIMIT_BURST=100

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable experimental features
FEATURE_EXPERIMENTAL=false

# Enable ML-based entity extraction
FEATURE_ML_EXTRACTION=true

# Enable real-time collaboration
FEATURE_REALTIME_COLLAB=false

# Enable document OCR processing
FEATURE_OCR_PROCESSING=true
